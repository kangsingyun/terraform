          "schema_version": 0,
          "attributes": {
            "content": "#!/bin/bash\r\n\r\ndnf install mariadb1011-client-utils -y\r\naws s3 cp s3://s3-xxxxx-board/db_init.sql /tmp/db_init.sql\r\n\r\nmariadb -h endpoint-xxxxxx -u root -p123 \u003c /tmp/db_init.sql\r\n\r\nsleep 6\r\nshutdown -P now\r\n\r\n",
