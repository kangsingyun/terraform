      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "content": "#!/bin/bash\r\n\r\ndnf install mariadb1011-client-utils -y\r\naws s3 cp s3://s3-511874874257-test-board/db_init.sql /tmp/db_init.sql\r\n\r\nmariadb -h database-board.c1kik0yioi4k.ap-northeast-2.rds.amazonaws.com -u root -pkang47290! \u003c /tmp/db_init.sql\r\n\r\nsleep 6\r\nshutdown -P now\r\n\r\n",
            "content_base64": null,
            "content_base64sha256": "+WE91y5fHrfqFum2EPPpzrt1Gf7eG55z21xHo2oG6tM=",
