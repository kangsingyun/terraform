    {
      "module": "module.files",
      "mode": "managed",
      "type": "local_file",
      "name": "web_script",
      "provider": "provider[\"registry.terraform.io/hashicorp/local\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "content": "#!/bin/bash\r\ndnf install httpd php8.4 php8.4-mysqlnd php8.4-pecl-redis6 -y\r\n    \r\naws s3 cp s3://s3-511874874257-board/test_board.tar.gz /tmp/test_board.tar.gz\r\ntar zxf /tmp/test_board.tar.gz -C /var/www/html\r\naws s3 cp s3://s3-511874874257-test-board/config.php /var/www/html/config.php\r\nsleep 3\r\naws s3 cp s3://s3-511874874257-test-board/www.conf /etc/php-fpm.d/www.conf\r\nsleep 3\r\nsystemctl restart httpd\r\nsystemctl enable httpd\r\n",
            "content_base64": null,
            "content_base64sha256": "lnGCGPfZ19HxqJCrU7Jti2xJ9zn2QaFSVe7ZLwwM6W0=",
            "content_base64sha512": "WSImaS3HJll21Xr8QNswsnKQqNArelkS0LoI6/4har0Jm2hE4k71LCuUvsvE5BhoOuYzMJt0pqo+pIwCqFaO/g==",
