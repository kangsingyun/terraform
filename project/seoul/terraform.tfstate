    {
      "module": "module.files",
      "mode": "managed",
      "type": "local_file",
      "name": "db_init",
      "provider": "provider[\"registry.terraform.io/hashicorp/local\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "content": "CREATE USER IF NOT EXISTS 'webmaster'@'%' IDENTIFIED BY '123';\r\nGRANT ALL PRIVILEGES ON test_board.* TO 'webmaster'@'%';\r\nCREATE DATABASE IF NOT EXISTS test_board DEFAULT CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;\r\nUSE test_board;\r\nCREATE TABLE IF NOT EXISTS users (username CHAR(16) NOT NULL PRIMARY KEY, password CHAR(41));\r\n\r\nINSERT IGNORE INTO users VALUES ('user1', '1234');\r\nINSERT IGNORE INTO users VALUES ('user2', '1234');\r\n\r\nCREATE TABLE IF NOT EXISTS board (\r\nid INT UNSIGNED AUTO_INCREMENT,\r\nuser VARCHAR(100) NOT NULL,\r\ntitle VARCHAR(100) NOT NULL,\r\ncomment TEXT NOT NULL,\r\nfile VARCHAR(100),\r\ndate DATETIME NOT NULL,\r\nPRIMARY KEY(id),\r\nFOREIGN KEY (user) REFERENCES users (username));\r\n",
            "content_base64": null,
            "content_base64sha256": "HcsS/uD4cSIv675kTQGK1v056QTqUry5/YlIHNfDVC4=",
            "content_base64sha512": "f8u+cFmEyGUvTN/7mOssvowwEBpB3WJ/2GYjVaskq3Cpjv8bTkcdD6SQRPN10O6j7UT2IMeo2NcHGQH/UwU8cQ==",
